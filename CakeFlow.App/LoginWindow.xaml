<Window x:Class="CakeFlow.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🍰 CakeFlow - Вход" 
        Height="500" Width="560" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="White">
    
    <Grid>
        <!-- ФОН: Тёмный градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1F14" Offset="0"/>
                <GradientStop Color="#1B3A2D" Offset="0.5"/>
                <GradientStop Color="#2A1F0D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- ДЕКОРАТИВНЫЕ ЭЛЕМЕНТЫ -->
        <Ellipse Width="200" Height="200" 
                 Fill="#C9A84C" Opacity="0.05"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,40,40,0"/>
        <Ellipse Width="150" Height="150" 
                 Fill="#C9A84C" Opacity="0.05"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="40,0,0,40"/>

        <!-- ЦЕНТРАЛЬНАЯ КАРТОЧКА -->
        <Border Width="420" 
                Background="#FFFFFF"
                CornerRadius="16"
                BorderBrush="#C9A84C"
                BorderThickness="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            
            <StackPanel>
                <!-- ЗОЛОТОЙ ВЕРХНИЙ БАР -->
                <Border Background="#1B3A2D"
                        Height="4"
                        CornerRadius="0"
                        Margin="0,0,0,0"/>

                <StackPanel Margin="30,30,30,30">
                    
                    <!-- ЛОГОТИП -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                        <TextBlock Text="🍰" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="СЛАДКИЙ РАЙ" 
                                   FontSize="24" FontWeight="Bold" 
                                   Foreground="#1B3A2D"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Премиум-кондитерская" 
                                   FontSize="12" 
                                   Foreground="#C9A84C"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <Border Width="60" Height="2" 
                                Background="#C9A84C"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                    </StackPanel>

                    <TextBlock Text="👤 Логин" 
                               FontWeight="SemiBold" 
                               FontSize="13" 
                               Margin="0,0,0,5"
                               Foreground="#6B6B6B"/>
                    <TextBox Name="txtLogin" Text="admin" FontSize="14" Margin="0,0,0,18"/>
                    
                    <TextBlock Text="🔒 Пароль" 
                               FontWeight="SemiBold" 
                               FontSize="13" 
                               Margin="0,0,0,5"
                               Foreground="#6B6B6B"/>
                    <PasswordBox Name="txtPassword" Password="admin123" FontSize="14" Margin="0,0,0,25"/>
                    
                    <Button Name="btnLogin" 
                            Content="🔑 Войти в систему" 
                            Click="Login_Click" 
                            Background="#C9A84C"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="16"
                            Height="48"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="10" 
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="20,10"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B8962A"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <TextBlock Name="lblError" 
                               Foreground="#D32F2F" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Center" 
                               FontSize="13" 
                               MinHeight="25"/>
                    
                    <Border Background="#F8F6F1" 
                            Padding="10" 
                            CornerRadius="6" 
                            Margin="0,10,0,0"
                            BorderBrush="#E8E0D6"
                            BorderThickness="1">
                        <TextBlock Text="📝 Тестовый вход: admin / admin123" 
                                   Foreground="#6B6B6B" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>