<Window x:Class="CakeFlow.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🍰 CakeFlow - Вход в систему учета заказов кондитерской Сладкий рай" 
        Height="450" Width="550" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Стиль для кнопки с закругленными углами -->
        <Style TargetType="Button" x:Key="RoundedButton">
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                             VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>
        
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F4F8">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
            
            <!-- Заголовок -->
            <Border Background="#2E7D32" Padding="20" CornerRadius="10" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="🍰 Сладкий рай" 
                               FontSize="32" FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Foreground="White"/>
                    <TextBlock Text="Система учета заказов" 
                               FontSize="16" 
                               HorizontalAlignment="Center" 
                               Foreground="#E8F5E9"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Форма входа -->
            <Border Background="White" Padding="30" CornerRadius="10" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    
                    <TextBlock Text="👤 Логин" Style="{StaticResource LabelStyle}"/>
                    <TextBox Name="txtLogin" Text="admin"/>
                    
                    <TextBlock Text="🔒 Пароль" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox Name="txtPassword" Password="admin123"/>
                    
                    <Button Name="btnLogin" Content="🔑 Войти в систему" 
                            Click="Login_Click" 
                            Style="{StaticResource RoundedButton}"
                            Margin="0,10,0,10"/>
                    
                    <TextBlock Name="lblError" Foreground="#D32F2F" TextWrapping="Wrap" 
                               HorizontalAlignment="Center" FontSize="14" MinHeight="30"
                               Margin="0,5,0,5"/>
                    
                    <Border Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,10,0,0">
                        <TextBlock Text="📝 Тестовый вход: admin / admin123" 
                                   Foreground="#666" FontSize="13" 
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>