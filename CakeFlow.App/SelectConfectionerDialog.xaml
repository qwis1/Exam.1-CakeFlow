<Window x:Class="CakeFlow.App.SelectConfectionerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👨‍🍳 Назначение кондитера" Height="300" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Background="#F5F5F5" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Выберите кондитера для заказа:" FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <ListBox Grid.Row="1" Name="lstConfectioners" DisplayMemberPath="FullName" 
                 SelectionMode="Single" Margin="0,0,0,15">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="10,5"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="btnAssign" Content="✅ Назначить" Click="Assign_Click" Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
            <Button Name="btnCancel" Content="❌ Отмена" Click="Cancel_Click" Width="100" Height="35" 
                    Background="#FF6B6B" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>