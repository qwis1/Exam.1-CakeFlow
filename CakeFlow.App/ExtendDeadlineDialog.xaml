<Window x:Class="CakeFlow.App.ExtendDeadlineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📅 Продление срока" Height="300" Width="450" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Background="#F5F5F5" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Продление срока выполнения" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Текущая дата:" FontWeight="Bold"/>
        <TextBlock Grid.Row="2" Name="lblCurrentDate" FontSize="14" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Новая дата получения:" FontWeight="Bold" Margin="0,0,0,3"/>
        <DatePicker Grid.Row="4" Name="dpNewDeadline" Height="30" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="5" Text="Причина продления:" FontWeight="Bold" Margin="0,0,0,3"/>
        <TextBox Grid.Row="6" Name="txtReason" Height="50" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="btnExtend" Content="✅ Продлить" Click="Extend_Click" Width="100" Height="35" 
                    Background="#FF5722" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
            <Button Name="btnCancel" Content="❌ Отмена" Click="Cancel_Click" Width="100" Height="35" 
                    Background="#9E9E9E" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>