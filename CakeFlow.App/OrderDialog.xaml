<Window x:Class="CakeFlow.App.OrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="🍰 Создание заказа" Height="650" Width="520" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Стиль для кнопки с закругленными углами -->
        <Style TargetType="Button" x:Key="RoundedButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🍰 Новый заказ" FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#333"/>

        <TextBlock Grid.Row="1" Text="👤 Клиент (ФИО):" FontWeight="Bold" Margin="0,0,0,3" FontSize="14"/>
        <TextBox Grid.Row="2" Name="txtClient" Height="35" FontSize="14" Margin="0,0,0,10" Padding="8"/>

        <TextBlock Grid.Row="3" Text="🎂 Название торта:" FontWeight="Bold" Margin="0,0,0,3" FontSize="14"/>
        <TextBox Grid.Row="4" Name="txtCakeName" Height="35" FontSize="14" Margin="0,0,0,10" Padding="8"/>

        <TextBlock Grid.Row="5" Text="📌 Тип торта:" FontWeight="Bold" Margin="0,0,0,3" FontSize="14"/>
        <ComboBox Grid.Row="6" Name="cmbCakeType" Height="35" FontSize="14" Margin="0,0,0,10">
            <ComboBoxItem Content="Свадебный" IsSelected="True"/>
            <ComboBoxItem Content="Детский"/>
            <ComboBoxItem Content="Праздничный"/>
            <ComboBoxItem Content="Корпоративный"/>
            <ComboBoxItem Content="Другой"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Text="📝 Описание (оформление, ингредиенты):" FontWeight="Bold" Margin="0,0,0,3" FontSize="14"/>
        <TextBox Grid.Row="8" Name="txtDescription" Height="60" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" FontSize="14" Padding="8"/>

        <TextBlock Grid.Row="9" Text="📅 Желаемая дата получения:" FontWeight="Bold" Margin="0,0,0,3" FontSize="14"/>
        <DatePicker Grid.Row="10" Name="dpDesiredDate" Height="35" FontSize="14" 
                    SelectedDate="{x:Static sys:DateTime.Now}" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="11" Text="💬 Комментарий:" FontWeight="Bold" Margin="0,0,0,3" FontSize="14"/>
        <TextBox Grid.Row="12" Name="txtComment" Height="50" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" FontSize="14" Padding="8"/>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Name="btnSave" Content="✅ Сохранить" Click="Save_Click" 
                    Style="{StaticResource RoundedButton}"
                    Background="#4CAF50" Margin="0,0,15,0"/>
            <Button Name="btnCancel" Content="❌ Отмена" Click="Cancel_Click" 
                    Style="{StaticResource RoundedButton}"
                    Background="#FF6B6B"/>
        </StackPanel>
    </Grid>
</Window>