<Window x:Class="CakeFlow.App.ManageUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CakeFlow.App"
        Title="👥 Управление пользователями" Height="450" Width="600" 
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    
    <Window.Resources>
        <local:RoleColorConverter x:Key="RoleColorConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👥 Список пользователей" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" Name="dgUsers" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionChanged="dgUsers_SelectionChanged"
                  AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="180"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{Binding Role, Converter={StaticResource RoleColorConverter}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Name="btnAddUser" Content="➕ Добавить пользователя" Click="AddUser_Click" 
                    Width="180" Height="35" Background="#4CAF50" Foreground="White" 
                    BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
            <Button Name="btnDeleteUser" Content="🗑️ Удалить" Click="DeleteUser_Click" 
                    Width="120" Height="35" Background="#FF6B6B" Foreground="White" 
                    BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
            <Button Name="btnRefresh" Content="🔄 Обновить" Click="Refresh_Click" 
                    Width="120" Height="35" Background="#4A90D9" Foreground="White" 
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>