<Window x:Class="CakeFlow.App.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="➕ Добавление пользователя" Height="380" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Background="#F5F5F5" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="➕ Новый пользователь" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="👤 Логин:" FontWeight="Bold" Margin="0,0,0,3"/>
        <TextBox Grid.Row="2" Name="txtLogin" Height="35" FontSize="14" Margin="0,0,0,10" Padding="8"/>

        <TextBlock Grid.Row="3" Text="🔒 Пароль:" FontWeight="Bold" Margin="0,0,0,3"/>
        <PasswordBox Grid.Row="4" Name="txtPassword" Height="35" FontSize="14" Margin="0,0,0,10" Padding="8"/>

        <TextBlock Grid.Row="5" Text="📛 ФИО:" FontWeight="Bold" Margin="0,0,0,3"/>
        <TextBox Grid.Row="6" Name="txtFullName" Height="35" FontSize="14" Margin="0,0,0,10" Padding="8"/>

        <TextBlock Grid.Row="7" Text="🎯 Роль:" FontWeight="Bold" Margin="0,0,0,3"/>
        <ComboBox Grid.Row="8" Name="cmbRole" Height="35" FontSize="14" Margin="0,0,0,15">
            <ComboBoxItem Content="Admin" Tag="Admin"/>
            <ComboBoxItem Content="Manager" Tag="Manager" IsSelected="True"/>
            <ComboBoxItem Content="Confectioner" Tag="Confectioner"/>
        </ComboBox>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="btnSave" Content="✅ Добавить" Click="Save_Click" Width="120" Height="40" 
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="16"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,15,0"/>
            <Button Name="btnCancel" Content="❌ Отмена" Click="Cancel_Click" Width="120" Height="40" 
                    Background="#FF6B6B" Foreground="White" FontWeight="Bold" FontSize="16"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>