<Window x:Class="CakeFlow.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CakeFlow.App"
        Title="🍰 CakeFlow" 
        Height="750" Width="1150" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F2EC">
    
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:RoleColorConverter x:Key="RoleColorConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНИЙ БАР -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="16"
                BorderBrush="#C9A84C"
                BorderThickness="1"
                Padding="18,12" 
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Border Background="#C9A84C"
                            Width="3" Height="24"
                            CornerRadius="2"
                            Margin="0,0,12,0"/>
                    <TextBlock Text="👤" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="Пользователь:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Name="lblUserFullName" Margin="6,0,20,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Border Background="#E8E0D6" Width="1" Height="24" Margin="0,0,15,0"/>
                    <TextBlock Text="🔑" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="Роль:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Name="lblUserRole" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button Content="🔄 Обновить" Click="Refresh_Click" 
                            Background="Transparent"
                            Foreground="#1B3A2D"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="12,6"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,8,0"/>
                    <Button Content="🚪 Выйти" Click="Logout_Click" 
                            Background="#C9A84C"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="16,6"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border Grid.Row="1" 
                Background="White"
                CornerRadius="16"
                BorderBrush="#E8E0D6"
                BorderThickness="1"
                Padding="16,12" 
                Margin="0,0,0,12">
            <WrapPanel>
                <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Name="txtSearch" 
                         Width="200" 
                         Margin="0,0,12,0" 
                         TextChanged="Search_TextChanged"/>
                
                <TextBlock Text="📌" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Name="cmbStatus" 
                          Width="140" 
                          Margin="0,0,12,0" 
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все заказы" IsSelected="True"/>
                    <ComboBoxItem Content="🟠 Новый"/>
                    <ComboBoxItem Content="🟡 В работе"/>
                    <ComboBoxItem Content="🟢 Готов"/>
                    <ComboBoxItem Content="🔵 Выдан"/>
                </ComboBox>

                <Separator Width="1" Background="#E8E0D6" Margin="0,0,12,0"/>

                <Button Name="btnAddOrder" 
                        Content="➕ Новый заказ" 
                        Click="AddOrder_Click" 
                        Background="#1B3A2D"
                        Foreground="#E8D5A3"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Padding="16,8"
                        BorderThickness="1"
                        BorderBrush="#C9A84C"
                        Cursor="Hand"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A5A45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Name="btnStatistics" 
                        Content="📊 Статистика" 
                        Click="ShowStatistics_Click" 
                        Background="#C9A84C"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Padding="16,8"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" 
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#B8962A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Name="btnManageUsers" 
                        Content="👥 Пользователи" 
                        Click="ManageUsers_Click" 
                        Background="Transparent"
                        Foreground="#1B3A2D"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Padding="16,8"
                        BorderThickness="1"
                        BorderBrush="#C9A84C"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C9A84C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>

        <!-- ТАБЛИЦА ЗАКАЗОВ -->
        <Border Grid.Row="2" 
                Background="White"
                CornerRadius="16"
                BorderBrush="#E8E0D6"
                BorderThickness="1"
                Padding="0">
            <DataGrid Name="dgOrders" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      SelectionChanged="Order_SelectionChanged"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="48"
                      FontSize="13"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E8E0D6"
                      VerticalGridLinesBrush="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#FAF8F5">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1B3A2D"/>
                        <Setter Property="Foreground" Value="#E8D5A3"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="42"/>
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="BorderBrush" Value="#2A5A45"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0EBE0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E8DCC8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ заказа" 
                                        Binding="{Binding OrderNumber}" 
                                        Width="110"/>
                    <DataGridTextColumn Header="Клиент" 
                                        Binding="{Binding ClientName}" 
                                        Width="130"/>
                    <DataGridTextColumn Header="Торт" 
                                        Binding="{Binding CakeName}" 
                                        Width="130"/>
                    <DataGridTextColumn Header="Тип" 
                                        Binding="{Binding CakeType}" 
                                        Width="100"/>
                    
                    <DataGridTemplateColumn Header="Статус" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="10,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="New">
                                                    <Setter Property="Background" Value="#FF6B6B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                    <Setter Property="Background" Value="#FFA500"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                    <Setter Property="Background" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Issued">
                                                    <Setter Property="Background" Value="#2196F3"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" 
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Срок" 
                                        Binding="{Binding DesiredDate, StringFormat=dd.MM.yyyy}" 
                                        Width="90"/>
                    <DataGridTextColumn Header="Кондитер" 
                                        Binding="{Binding AssignedToUserId}" 
                                        Width="100"/>
                    <DataGridTemplateColumn Header="⚠️" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="⚠️" 
                                           Foreground="#D32F2F" 
                                           FontSize="22" 
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsProblem, Converter={StaticResource BoolToVisibilityConverter}}"
                                           ToolTip="{Binding ProblemReason}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ДЕТАЛИ ЗАКАЗА -->
        <Border Grid.Row="3" 
                Background="White"
                CornerRadius="16"
                BorderBrush="#E8E0D6"
                BorderThickness="1"
                Padding="16,12" 
                Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Background="#C9A84C"
                            Width="3" Height="18"
                            CornerRadius="2"
                            Margin="0,0,10,0"/>
                    <TextBlock Text="📋 Детали заказа" 
                               FontWeight="SemiBold" 
                               FontSize="14"
                               Foreground="#1B3A2D"/>
                </StackPanel>

                <TextBox Name="txtOrderDetails" 
                         Grid.Row="1"
                         Height="70" 
                         TextWrapping="Wrap" 
                         IsReadOnly="True" 
                         Background="#FAF8F5" 
                         BorderBrush="#E8E0D6" 
                         BorderThickness="1" 
                         Padding="14,10" 
                         FontSize="13"
                         VerticalScrollBarVisibility="Auto"/>

                <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Name="btnChangeStatus" 
                            Content="🔄 Статус" 
                            Click="ChangeStatus_Click" 
                            Background="#1B3A2D"
                            Foreground="#E8D5A3"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="1"
                            BorderBrush="#C9A84C"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A5A45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="btnAssignConfectioner" 
                            Content="👨‍🍳 Назначить" 
                            Click="AssignConfectioner_Click" 
                            Background="Transparent"
                            Foreground="#1B3A2D"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="1"
                            BorderBrush="#C9A84C"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C9A84C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="btnAddComment" 
                            Content="💬 Коммент" 
                            Click="AddComment_Click" 
                            Background="Transparent"
                            Foreground="#1B3A2D"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="1"
                            BorderBrush="#C9A84C"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C9A84C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="btnShowComments" 
                            Content="📝 Все комм" 
                            Click="ShowComments_Click" 
                            Background="Transparent"
                            Foreground="#1B3A2D"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="1"
                            BorderBrush="#C9A84C"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C9A84C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="btnRequestHelp" 
                            Content="🆘 Помощь" 
                            Click="RequestHelp_Click" 
                            Background="#C9A84C"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B8962A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="btnResolveProblem" 
                            Content="✅ Решить" 
                            Click="ResolveProblem_Click" 
                            Background="#1B3A2D"
                            Foreground="#E8D5A3"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="1"
                            BorderBrush="#C9A84C"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A5A45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Name="btnExtendDeadline" 
                            Content="📅 Продлить" 
                            Click="ExtendDeadline_Click" 
                            Background="#C9A84C"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Padding="14,7"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B8962A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>